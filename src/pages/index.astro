---
// Pitzi Labs landing page — faithful port of the Claude Design handoff in
// design/. The sections are React components (src/components/) rendered
// SERVER-SIDE ONLY: there is NO client:* directive anywhere below, so no
// React ships to the browser — the build emits static HTML + the
// design-system CSS in public/. The dev-only Tweaks panel is dropped and its
// defaults are baked in: hero = dark, accent #e08438, status strip shown.
import Layout from '../layouts/Layout.astro';
import { NavBar } from '../components/Nav.jsx';
import { HeroDark } from '../components/Hero.jsx';
import { StatusStrip } from '../components/StatusStrip.jsx';
import { ServicesGrid } from '../components/Services.jsx';
import { CaseStudy } from '../components/CaseStudy.jsx';
import { Principles } from '../components/Principles.jsx';
import { Experience } from '../components/Experience.jsx';
import { Contact, Footer } from '../components/Contact.jsx';
---

<Layout>
  <NavBar active="Practice" />
  <HeroDark />
  <StatusStrip />
  <ServicesGrid />
  <CaseStudy />
  <Principles />
  <Experience />
  <Contact />
  <Footer />
</Layout>
